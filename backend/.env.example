# Cognitive Load Balancer — Environment Variables
# Copy this file to .env and fill in the values.

# Required: Your Groq API key for LLM question generation
GROQ_API_KEY=example
# Optional: Max questions per chunk before advancing to the next one (default 5)
MAX_QUESTIONS_PER_CHUNK=5

# Optional: Comma-separated frontend origins for CORS (default localhost:5173)
FRONTEND_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
